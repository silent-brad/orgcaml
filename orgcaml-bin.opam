opam-version: "2.0"
synopsis: "Org-mode to HTML CLI converter"
authors: ["Brad White"]
license: "MIT"
depends: [
  "ocaml" {>= "4.14"}
  "orgcaml" {= version}
  "dune" {>= "3.0" & >= "3.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
